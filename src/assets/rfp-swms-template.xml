  <!-- =======================================================================
       5. PARAGRAPH STYLES
       Source: word/styles.xml -> w:style elements
       ======================================================================= -->
  <ParagraphStyles>

    <!-- Normal: baseline for all paragraph styles -->
    <Style id="Normal" name="Normal" type="paragraph" default="true">
      <!-- Inherits all docDefaults; no overrides -->
    </Style>

    <!--
      Title: 36pt CAPS, majorHAnsi, color #404040, letter-spacing -10
      Used for document title inside first table row (gridSpan=5, centered)
    -->
    <Style id="Title" name="Title" type="paragraph" basedOn="Normal" next="Normal" uiPriority="10">
      <ParagraphProperties>
        <Spacing after="0" line="240" lineRule="auto"/>
        <ContextualSpacing enabled="true"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
        <Caps enabled="true"/>
        <Color value="404040" themeColor="text1" themeTint="BF"/>
        <Spacing value="-10"/>
        <Size val="72" unit="halfPoint"/>
        <!-- 36pt -->
      </RunProperties>
    </Style>

    <!--
      Subtitle: 14pt smallCaps, majorHAnsi, color #595959
    -->
    <Style id="Subtitle" name="Subtitle" type="paragraph" basedOn="Normal" next="Normal" uiPriority="11">
      <ParagraphProperties>
        <NumberingLevel ilvl="1"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
        <SmallCaps enabled="true"/>
        <Color value="595959" themeColor="text1" themeTint="A6"/>
        <Size val="28" unit="halfPoint"/>
        <!-- 14pt -->
      </RunProperties>
    </Style>

