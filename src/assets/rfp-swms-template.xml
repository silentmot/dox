      <ParagraphProperties>
        <KeepNext enabled="true"/>
        <KeepLines enabled="true"/>
        <Spacing before="400" after="40" line="240" lineRule="auto"/>
        <OutlineLevel val="0"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
        <Caps enabled="true"/>
        <Size val="36" unit="halfPoint"/>
        <!-- 18pt -->
      </RunProperties>
    </Style>

    <!--
      Heading 2: 14pt CAPS, majorHAnsi, outlineLevel=1
    -->
    <Style id="Heading2" name="heading 2" type="paragraph" basedOn="Normal" next="Normal" uiPriority="9">
      <ParagraphProperties>
        <KeepNext enabled="true"/>
        <KeepLines enabled="true"/>
        <Spacing before="120" after="0" line="240" lineRule="auto"/>
        <OutlineLevel val="1"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
        <Caps enabled="true"/>
        <Size val="28" unit="halfPoint"/>
        <!-- 14pt -->
      </RunProperties>
    </Style>

    <!--
      Heading 3: 14pt smallCaps, majorHAnsi, outlineLevel=2
    -->
    <Style id="Heading3" name="heading 3" type="paragraph" basedOn="Normal" next="Normal" uiPriority="9">
      <ParagraphProperties>
        <KeepNext enabled="true"/>
        <KeepLines enabled="true"/>
        <Spacing before="120" after="0" line="240" lineRule="auto"/>
        <OutlineLevel val="2"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
        <SmallCaps enabled="true"/>
        <Size val="28" unit="halfPoint"/>
        <!-- 14pt -->
      </RunProperties>
    </Style>

    <!--
      Heading 4: 11pt CAPS, majorHAnsi, outlineLevel=3
    -->
    <Style id="Heading4" name="heading 4" type="paragraph" basedOn="Normal" next="Normal" uiPriority="9">
      <ParagraphProperties>
        <KeepNext enabled="true"/>
        <KeepLines enabled="true"/>
        <Spacing before="120" after="0"/>
        <OutlineLevel val="3"/>
      </ParagraphProperties>
      <RunProperties>
        <Font theme="majorHAnsi"/>
