       Source: word/theme/theme1.xml -> a:fontScheme name="Tw Cen MT" ======================================================================= -->
  <FontScheme name="Tw Cen MT">
    <MajorFont latin="Tw Cen MT" panose="020B0602020104020603" arabicFallback="Arial" greekFallback="Calibri" cyrillicFallback="Calibri"/>
    <MinorFont latin="Tw Cen MT" panose="020B0602020104020603" arabicFallback="Arial" greekFallback="Calibri" cyrillicFallback="Calibri"/>
