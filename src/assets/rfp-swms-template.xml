    <Color role="lt1" value="FFFFFF" systemColor="window"/>
    <Color role="dk2" value="373545"/>
    <Color role="lt2" value="CEDBE6"/>
    <Color role="accent1" value="3494BA"/>
    <Color role="accent2" value="58B6C0"/>
    <Color role="accent3" value="75BDA7"/>
    <Color role="accent4" value="7A8C8E"/>
    <Color role="accent5" value="84ACB6"/>
    <Color role="accent6" value="2683C6"/>
