    <!--
      Heading 5: 11pt italic CAPS, majorHAnsi, outlineLevel=4
    -->
    <Style id="Heading5" name="heading 5" type="paragraph" basedOn="Normal" next="Normal" uiPriority="9">
      <ParagraphProperties>
        <KeepNext enabled="true"/>
        <KeepLines enabled="true"/>
