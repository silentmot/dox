        <Color value="276E8B" themeColor="accent1" themeShade="BF"/>
        <Size val="26" unit="halfPoint"/>
        <!-- 13pt -->
      </RunProperties>
      <Field type="PAGE" format="\* MERGEFORMAT"/>
    </Paragraph>
    <!-- Trailing empty paragraph with Footer style -->
    <Paragraph style="Footer"/>
  </FooterLayout>

