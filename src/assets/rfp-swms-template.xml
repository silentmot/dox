    <TextBox name="DocTitle">
      <Position horizontal="-276832" vertical="383847" unit="EMU" relativeFrom="column"/>
      <Size width="2360930" height="1404620" unit="EMU"/>
      <Content>
        <Paragraph alignment="center">
          <Run size="18" sizeUnit="halfPoint">            <!-- 9pt -->
