  </ParagraphStyles>

  <!-- =======================================================================
       6. TABLE STYLES
       Source: word/styles.xml -> w:style type="table" ======================================================================= -->
  <TableStyles>

    <!--
      TableNormal: base for all table styles
      Cell margins: top=0, left=108, bottom=0, right=108 DXA
    -->
    <Style id="TableNormal" name="Normal Table" type="table" default="true">
      <TableProperties>
        <Indent width="0" type="dxa"/>
        <CellMargins top="0" left="108" bottom="0" right="108" unit="DXA"/>
      </TableProperties>
    </Style>

    <!--
      TableNormal0: custom base used by inline table styles (a, a0, a1, a2)
      Cell margins: 100 DXA on all sides (larger padding)
    -->
    <Style id="TableNormal0" name="TableNormal" type="table" custom="true">
      <TableProperties>
        <CellMargins top="100" left="100" bottom="100" right="100" unit="DXA"/>
      </TableProperties>
    </Style>

    <!--
      PlainTable3: used for the metadata/title table at document top
      Built-in Word style with firstRow, firstCol, band1Horz formatting
      Source: styles.xml lines 1203-1353
    -->
    <Style id="PlainTable3" name="Plain Table 3" type="table" basedOn="TableNormal" uiPriority="43">
      <TableProperties>
        <RowBandSize val="1"/>
        <ColBandSize val="1"/>
      </TableProperties>
      <ConditionalFormats>
        <FirstRow>
          <RunProperties>
            <Bold enabled="true"/>
            <Caps enabled="true"/>
          </RunProperties>
          <CellProperties>
            <Borders>
              <Bottom style="single" size="4" space="0" color="7F7F7F" themeColor="text1" themeTint="80"/>
            </Borders>
          </CellProperties>
        </FirstRow>
        <LastRow>
          <RunProperties>
            <Bold enabled="true"/>
            <Caps enabled="true"/>
          </RunProperties>
          <CellProperties>
            <Borders>
              <Top style="nil"/>
            </Borders>
          </CellProperties>
        </LastRow>
        <FirstCol>
          <RunProperties>
            <Bold enabled="true"/>
            <Caps enabled="true"/>
          </RunProperties>
          <CellProperties>
            <Borders>
              <Right style="single" size="4" space="0" color="7F7F7F" themeColor="text1" themeTint="80"/>
            </Borders>
          </CellProperties>
        </FirstCol>
        <Band1Horz>
          <CellProperties>
            <Shading val="clear" color="auto" fill="F2F2F2" themeFill="background1" themeFillShade="F2"/>
          </CellProperties>
        </Band1Horz>
        <Band1Vert>
          <CellProperties>
            <Shading val="clear" color="auto" fill="F2F2F2" themeFill="background1" themeFillShade="F2"/>
          </CellProperties>
        </Band1Vert>
      </ConditionalFormats>
    </Style>

    <!--
      EcoSolDataTable: two-line minimal table style for data tables
      Source: User-confirmed XML table template (March 2026)

      Borders:
        - Header row: bottom border only (horizontal separator under header)
        - Data rows: right border on first column only (vertical divider)
        - No outer borders, no other inner borders

      Shading:
        - First column: never shaded (always white)
        - Columns 2+: banded horizontal (odd data rows #F2F2F2, even white)

      Layout:
        - Header: bold, center-aligned, repeats on page break
        - Cell padding: 100 DXA (~0.07") all sides
        - Cell text: 10pt (20 half-points)
    -->
    <Style id="EcoSolDataTable" name="EcoSol Data Table" type="table" custom="true">
      <TableProperties>
        <TableBorders>
          <Top style="nil"/>
          <Left style="nil"/>
          <Bottom style="nil"/>
          <Right style="nil"/>
          <InsideH style="nil"/>
          <InsideV style="nil"/>
        </TableBorders>
        <CellMargins top="100" left="100" bottom="100" right="100" unit="DXA"/>
      </TableProperties>
      <ConditionalFormats>
        <HeaderRow>
          <RunProperties>
            <Bold enabled="true"/>
            <Size val="20" unit="halfPoint"/><!-- 10pt -->
          </RunProperties>
          <ParagraphProperties>
            <Alignment horizontal="center"/>
          </ParagraphProperties>
          <CellProperties>
            <Borders>
              <Bottom style="single" size="6" space="0" color="7F7F7F"/>
            </Borders>
            <VerticalAlignment val="center"/>
          </CellProperties>
          <RowProperties>
            <RepeatOnPageBreak enabled="true"/>
            <MinHeight val="360" unit="DXA"/>
          </RowProperties>
        </HeaderRow>
        <FirstCol scope="dataRowsOnly">
          <CellProperties>
            <Borders>
              <Right style="single" size="4" space="0" color="7F7F7F"/>
            </Borders>
            <Shading val="none"/><!-- First column never shaded -->
          </CellProperties>
        </FirstCol>
        <Band1Horz scope="columns2PlusOnly">
          <CellProperties>
            <Shading val="clear" color="auto" fill="F2F2F2"/>
          </CellProperties>
        </Band1Horz>
      </ConditionalFormats>
      <DataRowDefaults>
        <RunProperties>
          <Size val="20" unit="halfPoint"/><!-- 10pt -->
        </RunProperties>
        <CellProperties>
          <VerticalAlignment val="center"/>
          <MinHeight val="320" unit="DXA"/>
        </CellProperties>
      </DataRowDefaults>
    </Style>

    <!--
      Custom table styles (a, a0, a1, a2): Google Docs-origin inline tables
      All share identical structure: basedOn TableNormal0, firstRow uses
      Inter Medium font at 11pt, color #1F1F1F, fill #F2F2EF, no top border,
      vertical center alignment.
      Use when replicating the document's data-entry table patterns.
    -->
    <Style id="CustomInlineTable" name="EcoSol Inline Table" type="table" basedOn="TableNormal0" custom="true" note="Replaces styles a/a0/a1/a2 from source; all are identical">
      <TableProperties>
        <RowBandSize val="1"/>
        <ColBandSize val="1"/>
      </TableProperties>
      <ConditionalFormats>
        <FirstRow>
          <RunProperties>
            <Font ascii="Inter Medium" eastAsia="Inter Medium" hAnsi="Inter Medium" cs="Inter Medium"/>
            <Color value="1F1F1F"/>
            <Size val="22" unit="halfPoint"/>
            <!-- 11pt -->
          </RunProperties>
          <CellProperties>
            <Borders>
              <Top style="nil"/>
            </Borders>
            <Shading val="clear" color="auto" fill="F2F2EF"/>
            <VerticalAlignment val="center"/>
          </CellProperties>
        </FirstRow>
      </ConditionalFormats>
    </Style>

  </TableStyles>

  <!-- =======================================================================
       7. TABLE USAGE PATTERNS (from document.xml)
       ======================================================================= -->
  <TablePatterns>

    <!--
      Pattern A: Metadata/Title Table (PlainTable3)
      Used at document top for RFP title + metadata fields
      5 columns, first row spans all 5 (gridSpan=5) for centered title
    -->
    <Pattern name="MetadataTitleTable" style="PlainTable3">
      <TableWidth type="auto"/>
      <GridColumns>
        <Column width="1679"/>
        <Column width="2597"/>
        <Column width="1668"/>
        <Column width="1256"/>
        <Column width="2160"/>
      </GridColumns>
      <TableLook firstRow="1" lastRow="0" firstColumn="1" lastColumn="0" noHBand="0" noVBand="1" lookValue="04A0"/>
      <Notes>
        Row 1: Title style, centered, gridSpan=5, no bold override (b val=0), CAPS, 18pt, auto color.
        Row 2+: Metadata key-value pairs. First column is label (bold via firstCol conditional).
        Row heights: 357 DXA for header, 276 DXA for data rows.
      </Notes>
    </Pattern>

    <!--
      Pattern B: Data Table (EcoSolDataTable)
      Two-line minimal style for all data tables in BRS/RFP documents.
      Columns auto-distributed across 9360 DXA content width.
    -->
    <Pattern name="DataTable" style="EcoSolDataTable">
      <TableWidth size="9360" type="DXA"/><!-- Full content width -->
      <GridColumns distribution="equal"/><!-- Columns calculated at runtime by mapper -->
      <Notes>
        Header row: bold, center-aligned, bottom border #7F7F7F sz=6, repeats on page break.
        First column: right border #7F7F7F sz=4 (vertical divider), never shaded.
        Columns 2+: banded horizontal (odd data rows #F2F2F2, even white).
        Cell padding: 100 DXA all sides. Cell text: 10pt.
      </Notes>
    </Pattern>

  </TablePatterns>

  <!-- =======================================================================
