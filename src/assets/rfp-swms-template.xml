    <!-- Header style: Normal + tab stops at center (4680) and right (9360) -->
    <Style id="Header" name="header" type="paragraph" basedOn="Normal" uiPriority="99">
      <ParagraphProperties>
        <TabStops>
          <Tab val="center" pos="4680"/>
          <Tab val="right" pos="9360"/>
        </TabStops>
      </ParagraphProperties>
    </Style>

    <!-- Footer style: Normal + tab stops at center (4680) and right (9360) -->
    <Style id="Footer" name="footer" type="paragraph" basedOn="Normal" uiPriority="99">
      <ParagraphProperties>
        <TabStops>
          <Tab val="center" pos="4680"/>
