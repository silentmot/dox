  </HeaderLayout>

  <!-- =======================================================================
       9. FOOTER LAYOUT
       Source: word/footer1.xml
       ======================================================================= -->
  <FooterLayout>
    <!--
      Single paragraph with left accent border, PAGE field
      Font: majorHAnsi 13pt, color accent1 shade BF (#276E8B)
